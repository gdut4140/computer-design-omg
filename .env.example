# ==========================================
# StarEye Screening System — 环境变量配置
# ==========================================
# 复制此文件为 .env 并填入实际配置值
# .env 文件不会被提交到 Git

# -------------------- API 配置 --------------------

# 后端 API 代理目标地址（开发环境）
VITE_API_PROXY_TARGET=http://localhost:8080

# API 基础路径
VITE_API_BASE_URL=/api

# -------------------- 存储键名 --------------------

# localStorage 中存储 Token 的 Key
VITE_TOKEN_KEY=stareye_token

# localStorage 中存储用户信息的 Key
VITE_USER_KEY=stareye_user
